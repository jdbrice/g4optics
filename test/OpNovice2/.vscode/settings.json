{
  "C_Cpp.default.compileCommands": "${workspaceFolder}/build-gui/compile_commands.json",
  "C_Cpp.default.compilerPath": "/usr/bin/c++",
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.intelliSenseMode": "linux-gcc-arm64",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/include",
    "/opt/geant4/include/Geant4",
    "/usr/include",
    "/usr/include/aarch64-linux-gnu"
  ],
  "C_Cpp.autocomplete": "default",
  "C_Cpp.errorSquiggles": "enabled",
  "cmake.buildDirectory": "${workspaceFolder}/build-gui",
  "cmake.configureArgs": [
    "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
  ]
}
